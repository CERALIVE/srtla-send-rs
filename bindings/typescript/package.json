{
	"name": "@ceralive/srtla-send",
	"version": "2026.6.2",
	"packageManager": "pnpm@10.30.3",
	"description": "Type-safe helpers for the srtla-send-rs sender (args, validation, telemetry reader).",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./sender": {
			"import": "./dist/sender/index.js",
			"types": "./dist/sender/index.d.ts"
		},
		"./telemetry": {
			"import": "./dist/telemetry/index.js",
			"types": "./dist/telemetry/index.d.ts"
		},
		"./control": {
			"import": "./dist/control/index.js",
			"types": "./dist/control/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@ceralive/biome-config": "^2026.6.2",
		"@types/bun": "^1.3.14",
		"typescript": "^7.0.2"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CERALIVE/srtla-send-rs.git"
	},
	"license": "AGPL-3.0",
	"keywords": [
		"srtla",
		"srt",
		"ceralive",
		"link-aggregation",
		"sender",
		"cli",
		"bindings"
	]
}
